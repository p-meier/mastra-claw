# MastraClaw — Layer A bootstrap env vars
#
# These are the ONLY env vars MastraClaw reads. Everything else (LLM provider
# keys, ElevenLabs, Telegram bot tokens, MCP auth, …) lives in Supabase Vault
# and is configured per-user via the in-app setup wizard.
#
# Copy this file to .env.local and fill in the values from the Supabase
# dashboard (Project Settings → Database / API / Storage).
#
# Public-vs-secret split:
#   NEXT_PUBLIC_*           ← exposed to the browser bundle. ONLY for keys
#                              that Supabase explicitly documents as public
#                              (URL + publishable key).
#   SUPABASE_SERVICE_ROLE_KEY,
#   DATABASE_URL,
#   DATABASE_SSL,
#   SUPABASE_S3_*           ← server-only. NEVER prefix with NEXT_PUBLIC_.

# === Public (browser-safe) Supabase config ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# === Server-only Supabase secrets ===
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DATABASE_SSL=true

# === Optional: Supabase Storage / S3 ===
# SUPABASE_S3_ENDPOINT=https://<REF>.supabase.co/storage/v1/s3
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
#
# That's it. No model names, no voice IDs, no per-feature toggles, no
# LLM API keys. Per-deployment defaults live in `src/lib/defaults.ts`,
# admin overrides live in the `app_settings` table (editable from
# /admin/settings), and per-user secrets live in Supabase Vault. The
# admin setup wizard at /admin/setup writes everything else.
